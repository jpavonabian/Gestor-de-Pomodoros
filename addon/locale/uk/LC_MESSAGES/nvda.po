#: addon\globalPlugins\GestorDePomodoros.py:78
msgid "Ciclo completado. Iniciando descanso."
msgstr "Цикл завершено. Починається перерва."

#: addon\globalPlugins\GestorDePomodoros.py:86
msgid "Descanso largo finalizado. Iniciando nuevo ciclo."
msgstr "Довгу перерву завершено. Починається новий цикл."

#: addon\globalPlugins\GestorDePomodoros.py:89
msgid "Descanso finalizado. Iniciando nuevo ciclo."
msgstr "Перерву завершено. Починається новий цикл."

