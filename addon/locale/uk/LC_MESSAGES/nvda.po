msgstr "Перерва триває. Залишок часу: {minutes} хвилин і {seconds} секунд."

#: addon\globalPlugins\GestorDePomodoros.py:106
#, python-brace-format
msgid ""
"Ciclo en progreso. Tiempo restante: {minutes} minutos y {seconds} segundos."
msgstr "Цикл триває. Залишок часу: {minutes} хвилин і {seconds} секунд."

#: addon\globalPlugins\GestorDePomodoros.py:140
